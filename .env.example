# Copy this file to `.env` when you want local overrides for the CLI or API server.

# Base project directory. Other paths derive from this unless you set them explicitly.
WORKLEDGER_PROJECT_DIR=.workledger

# Optional explicit database path if you do not want the default derived location.
# WORKLEDGER_DATABASE_PATH=.workledger/workledger.duckdb

# API server bind settings.
WORKLEDGER_HOST=127.0.0.1
WORKLEDGER_PORT=8000

# Required for protected API routes. For local-only experiments, you can leave this
# unset and opt into open access with WORKLEDGER_ALLOW_UNAUTHENTICATED_API=true.
# WORKLEDGER_API_KEY=replace-me
# WORKLEDGER_ALLOW_UNAUTHENTICATED_API=false

# Request safety limits for ingestion APIs.
WORKLEDGER_MAX_BATCH_SIZE=10000
WORKLEDGER_MAX_PAYLOAD_BYTES=2000000
