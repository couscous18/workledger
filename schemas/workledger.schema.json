        "SpanKind": {
          "enum": [
            "root",
            "llm",
            "agent",
            "tool",
            "retriever",
            "evaluator",
            "guardrail",
            "review",
            "io",
            "other"
          ],
          "title": "SpanKind",
          "type": "string"
        },
        "TokenTax": {
          "additionalProperties": false,
          "properties": {
            "name": {
              "title": "Name",
              "type": "string"
            },
            "jurisdiction": {
              "title": "Jurisdiction",
              "type": "string"
            },
            "rate": {
              "minimum": 0.0,
              "title": "Rate",
              "type": "number"
            },
            "taxable_tokens": {
              "anyOf": [
                {
                  "minimum": 0,
                  "type": "integer"
