                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Taxable Tokens"
            },
            "amount": {
              "anyOf": [
                {
                  "minimum": 0.0,
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Amount"
            },
            "currency": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "title": "Currency"
            },
            "included_in_direct_cost": {
              "default": false,
              "title": "Included In Direct Cost",
              "type": "boolean"
            }
          },
          "required": [
            "name",
            "jurisdiction",
            "rate"
          ],
          "title": "TokenTax",
          "type": "object"
