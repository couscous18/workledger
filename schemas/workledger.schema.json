          "default": null,
          "title": "Parent Span Id"
        },
        "span_kind": {
          "$ref": "#/definitions/SpanKind",
          "default": "other"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "start_time": {
          "format": "date-time",
          "title": "Start Time",
          "type": "string"
        },
        "end_time": {
          "format": "date-time",
          "title": "End Time",
          "type": "string"
        },
        "model_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model Name"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "tool_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
