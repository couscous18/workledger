        },
        "masked": {
          "default": false,
          "title": "Masked",
          "type": "boolean"
        },
        "redaction_applied": {
          "default": false,
          "title": "Redaction Applied",
          "type": "boolean"
        },
        "work_unit_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Work Unit Key"
        },
        "facets": {
          "additionalProperties": true,
          "title": "Facets",
          "type": "object"
        }
      },
      "required": [
        "source_kind",
        "trace_id",
        "span_id",
        "name",
        "start_time",
        "end_time"
