        "direct_cost": {
          "default": 0.0,
          "title": "Direct Cost",
          "type": "number"
        },
        "status": {
          "default": "ok",
          "title": "Status",
          "type": "string"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "raw_payload_ref": {
          "anyOf": [
            {
              "type": "string"
